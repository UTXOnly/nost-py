server{
    listen 80;
    listen 443 ssl;
    server_name no.dojotunnel.online;
    ssl_certificate /etc/letsencrypt/live/no.dojotunnel.online/cert.pem;
    ssl_certificate_key /etc/letsencrypt/live/no.dojotunnel.online/privkey.pem;
    location / {
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header Host \$host;
        proxy_pass http://172.20.0.2:8008;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}